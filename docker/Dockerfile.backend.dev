# Development Dockerfile for backend with cargo-watch hot-reload

ARG RUST_VERSION=1.97

FROM rust:${RUST_VERSION}-trixie

# Install build dependencies, cargo-watch, and sccache
RUN apt-get update && apt-get upgrade -y && apt-get install -y --no-install-recommends \
    curl \
    liblzma-dev \
    libssl-dev \
    pkg-config \
    protobuf-compiler \
    zlib1g-dev \
    && find /var/cache/apt/archives/ /var/lib/apt/lists/ -mindepth 1 -delete \
    && cargo install cargo-watch@8.5.3 --locked \
    && cargo install sccache --locked

# Configure sccache as the Rust compiler wrapper
ENV RUSTC_WRAPPER=sccache
ENV SCCACHE_DIR=/sccache
ENV SCCACHE_CACHE_SIZE=10G

WORKDIR /app

# Source and target will be mounted at runtime
EXPOSE 8080 9090

RUN groupadd -r appuser && useradd -r -g appuser -d /app appuser \
    && chown -R appuser:appuser /usr/local/cargo \
    && mkdir -p /target /sccache \
    && chown appuser:appuser /target /sccache /app
USER appuser

CMD ["cargo", "watch", "-x", "run --bin artifact-keeper"]
